{
  "name": "danish-football-clubs",
  "version": "1.2.13",
  "description": "Club data and DBU utilities for Danish youth football",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./teams": "./teams.js",
    "./bydel": "./bydel.js",
    "./global": "./global.js"
  },
  "files": [
    "index.js",
    "teams.js",
    "bydel.js",
    "global.js",
    "assets"
  ],
  "keywords": [
    "danish",
    "football",
    "dbu",
    "clubs"
  ],
  "license": "MIT",
  "devDependencies": {
    "@supabase/supabase-js": "^2.106.0"
  },
  "scripts": {
    "scrape": "node scripts/scrapeClubs.js",
    "build": "node scripts/buildIndex.js",
    "figma": "node scripts/buildFigmaPlugin.js",
    "logos": "node scripts/mergeLogos.js && node scripts/buildIndex.js",
    "enrich": "node scripts/enrichClubs.js && node scripts/buildIndex.js",
    "scrape-teams": "node scripts/scrapeTeams.js",
    "scrape-bydel": "node scripts/scrapeBydel.js",
    "build-teams": "node scripts/buildTeams.js",
    "build-bydel": "node scripts/buildBydel.js",
    "build-all": "npm run build && npm run build-teams && npm run build-bydel",
    "editor": "node scripts/editor-server.js",
    "sync-kits": "node scripts/syncKitContributions.js && node scripts/buildIndex.js",
    "release": "git push origin main && git push origin v$npm_package_version"
  },
  "dependencies": {
    "google-play-scraper": "^10.1.3"
  }
}
