{
  "name": "danish-football-clubs",
  "version": "1.1.10",
  "description": "Club data and DBU utilities for Danish youth football",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./global": "./global.js"
  },
  "files": [
    "index.js",
    "global.js",
    "assets"
  ],
  "keywords": [
    "danish",
    "football",
    "dbu",
    "clubs"
  ],
  "license": "MIT",
  "scripts": {
    "scrape": "node scripts/scrapeClubs.js",
    "build": "node scripts/buildIndex.js",
    "figma": "node scripts/buildFigmaPlugin.js",
    "logos": "node scripts/mergeLogos.js && node scripts/buildIndex.js",
    "editor": "node scripts/editor-server.js",
    "release": "git push origin main && git push origin v$npm_package_version"
  }
}
